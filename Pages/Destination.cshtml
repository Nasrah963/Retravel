@page
@model DB_Project.Pages.travel_destinationModel
@{
}


<!-- bradcam_area  -->
<div class="bradcam_area bradcam_bg_2">
    <div class="container">
        <div class="row">
            <div class="col-xl-12">
                <div class="bradcam_text text-center">
                    <h3>Destinations</h3>
                    <p>Pixel perfect design with awesome contents</p>
                </div>
            </div>
        </div>
    </div>
</div>
<!--/ bradcam_area  -->
<!-- where_togo_area_start  -->
<div class="where_togo_area">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-3">
            </div>
            <div class="col-lg-9">
                <div class="search_wrap">
                   
                </div>
            </div>
        </div>
    </div>
</div>
<!-- where_togo_area_end  -->


<div class="popular_places_area">
    <div class="container">
        <div class="row">
            <div class="col-lg-4">
                <div class="filter_result_wrap">
                    <h3>  </h3>
                    <div class="">
                        <div class="filter_inner">
                            <div class="row">
                                <div class="col-lg-12">
                                </div>
                                <div class="col-lg-12">
                                </div>
                                <div class="col-lg-12">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="row">
                    @for (int i = 0; i < Model.dtt.Rows.Count;i ++)
                    {
                        <div class="col-lg-6 col-md-6">
                            <div class="single_place">
                                <div class="thumb">
                                    <img src="img/Retravel/@Model.dtt.Rows[i][5]" alt="" height="200px">
                                    <a href="#" class="prise">@Model.dtt.Rows[i][2]</a>
                                </div>
                                <div class="place_info">
                                    <a  asp-page="/Destination_details" asp-route-id="@Model.dtt.Rows[i][0]"><h3>@Model.dtt.Rows[i][1]</h3></a>
                                    <p>Egypt</p>
                                    <div class="rating_days d-flex justify-content-between">
                                        <span class="d-flex justify-content-center align-items-center">
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <a href="#">(20 Review)</a>
                                        </span>
                                        <div class="days">
                                            <i class="fa fa-clock-o"></i>
                                            <a href="#">@(((DateTime)Model.dtt.Rows[i][6]).ToString("MMMM dd, yyyy"))</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>               
            </div>
        </div>
    </div>
</div>

<!-- newletter_area_start  -->
<div class="newletter_area overlay">
    <div class="container">
        <div class="row justify-content-center align-items-center">
            <div class="col-lg-10">
                <div class="row align-items-center">
                    <div class="col-lg-5">
                        <div class="newsletter_text">
                            <h4> LIVE YOUR LIFE BY A COMPASS, NOT A CLOCK </h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- newletter_area_end  -->
<div class="recent_trip_area">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="section_title text-center mb_70">
                    <h3>Recent Trips</h3>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-4 col-md-6">
                <div class="single_trip">
                    <div class="thumb">
                        <img src="img/Retravel/@Model.dt.Rows[0][5]" alt="">
                    </div>
                    <div class="info">
                        <div class="date">
                            <span>@(((DateTime)Model.dt.Rows[0][6]).ToString("MMMM dd, yyyy"))</span>
                        </div>
                        <a asp-page="/Destination_details" asp-route-id="@Model.dt.Rows[0][0]">
                            <h3>
                                @Model.dt.Rows[0][10]
                            </h3>
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="single_trip">
                    <div class="thumb">
                        <img src="img/Retravel/@Model.dt.Rows[1][5]" alt="">
                    </div>
                    <div class="info">
                        <div class="date">
                            <span>@(((DateTime)Model.dt.Rows[1][6]).ToString("MMMM dd, yyyy"))</span>
                        </div>
                        <a asp-page="/Destination_details" asp-route-id="@Model.dt.Rows[1][0]">
                            <h3>
                                @Model.dt.Rows[1][10]
                            </h3>
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="single_trip">
                    <div class="thumb">
                        <img src="img/Retravel/@Model.dt.Rows[2][5]" alt="">
                    </div>
                    <div class="info">
                        <div class="date">
                            <span>@(((DateTime)Model.dt.Rows[2][6]).ToString("MMMM dd, yyyy"))</span>
                        </div>
                        <a asp-page="/Destination_details" asp-route-id="@Model.dt.Rows[2][0]">
                            <h3>
                                @Model.dt.Rows[2][10]
                            </h3>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="video_area video_bg overlay">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="video_wrap text-center">
                    <h3>Enjoy Video</h3>
                    <div class="video_icon">
                        <a class="popup-video video_play_button" href="https://www.youtube.com/watch?v=t1hPHPHBODA">
                            <i class="fa fa-play"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>